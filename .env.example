# Model providers
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
OPENAI_MODEL_ID=gpt-4o-mini
GEMINI_MODEL_ID=gemini-2.0-flash

# Database (swappable; schema created via `alembic upgrade head`)
DATABASE_URL=postgresql+psycopg2://invoice:invoice@localhost:5432/invoices

# Business config (optional; defaults shown)
TAX_RATE=0.09125
SUPPORTED_CURRENCIES=USD
MAX_UPLOAD_MB=10
