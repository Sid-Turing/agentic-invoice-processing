# Model providers
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
OPENAI_MODEL_ID=gpt-5.5-2026-04-23
GEMINI_MODEL_ID=gemini-2.5-flash

# Database (swappable; schema created via `alembic upgrade head`)
DATABASE_URL=postgresql+psycopg2://invoice:invoice@localhost:5434/invoices

# Business config (optional; defaults shown)
TAX_RATE=0.09125
SUPPORTED_CURRENCIES=USD
MAX_UPLOAD_MB=10
